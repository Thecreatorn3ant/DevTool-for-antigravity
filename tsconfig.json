{
    "compilerOptions": {
        "module": "Node16",
        "target": "ES2022",
        "outDir": "out",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "strict": true,
        "noImplicitAny": true,
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "types": ["node"],
        "ignoreDeprecations": "6.0"
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}